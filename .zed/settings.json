{
	"format_on_save": "on",
	"hard_tabs": true,
	"prettier": { "allowed": false },
	"preferred_line_length": 84,

	"terminal": { "env": { "GIT_EDITOR": "zed --wait" } },

	"file_types": {
		"Dockerfile": ["dockerfile", "dockerfile.*"]
	},

	"lsp": {
		"oxlint": {
			"initialization_options": { "settings": { "typeAware": true } }
		},

		"tailwindcss-language-server": {
			"settings": {
				"validate": true,
				"classAttributes": [
					"class",
					"className",
					".+ClassName",
					".+ClassNames"
				],
				"classFunctions": ["twMerge", "twJoin"],
				"experimental": { "configFile": { "src/index.css": "src/**/*" } }
			}
		}
	},

	"languages": {
		"TypeScript": {
			"language_servers": [
				"tsgo",
				"oxlint",
				"tailwindcss-language-server",
				"oxfmt"
			],
			"formatter": [{ "language_server": { "name": "oxfmt" } }],
			"code_actions_on_format": { "source.fixAll.oxc": true }
		},

		"TSX": {
			"language_servers": [
				"tsgo",
				"oxlint",
				"tailwindcss-language-server",
				"oxfmt"
			],
			"formatter": [{ "language_server": { "name": "oxfmt" } }],
			"code_actions_on_format": { "source.fixAll.oxc": true }
		},

		"JavaScript": {
			"language_servers": ["tsgo", "oxlint", "oxfmt"],
			"formatter": [{ "language_server": { "name": "oxfmt" } }],
			"code_actions_on_format": { "source.fixAll.oxc": true }
		},

		"CSS": {
			"language_servers": [
				"tailwindcss-language-server",
				"tailwindcss-intellisense-css",
				"oxfmt",
				"!vscode-css-language-server"
			],
			"formatter": [{ "language_server": { "name": "oxfmt" } }]
		},

		"HTML": {
			"formatter": [{ "language_server": { "name": "oxfmt" } }]
		},

		"Markdown": {
			"formatter": [{ "language_server": { "name": "oxfmt" } }]
		},

		"JSON": {
			"formatter": [{ "language_server": { "name": "oxfmt" } }]
		},

		"JSONC": {
			"formatter": [{ "language_server": { "name": "oxfmt" } }]
		},

		"YAML": {
			"formatter": [{ "language_server": { "name": "oxfmt" } }]
		},

		"TOML": {
			"formatter": [{ "language_server": { "name": "tombi" } }]
		}
	}
}

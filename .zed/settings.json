{
	"format_on_save": "on",
	"hard_tabs": true,
	"preferred_line_length": 84,
	"prettier": { "allowed": false },
	"formatter": [{ "language_server": { "name": "oxfmt" } }],

	"lsp": {
		"tailwindcss-language-server": {
			"settings": {
				"validate": true,
				"classAttributes": [
					"class",
					"className",
					".+ClassName",
					".+ClassNames"
				],
				"classFunctions": ["twMerge", "twJoin"],
				"experimental": { "configFile": { "src/index.css": "src/**/*" } }
			}
		}
	},

	"languages": {
		"TypeScript": {
			"language_servers": [
				"tsgo",
				"oxlint",
				"tailwindcss-language-server",
				"oxfmt"
			],
			"code_actions_on_format": { "source.fixAll.oxc": true }
		},

		"TSX": {
			"language_servers": [
				"tsgo",
				"oxlint",
				"tailwindcss-language-server",
				"oxfmt"
			],
			"formatter": [{ "language_server": { "name": "oxfmt" } }],
			"code_actions_on_format": { "source.fixAll.oxc": true }
		},

		"JavaScript": {
			"language_servers": ["tsgo", "oxlint", "oxfmt"],
			"code_actions_on_format": { "source.fixAll.oxc": true }
		},

		"CSS": {
			"language_servers": [
				"tailwindcss-language-server",
				"tailwindcss-intellisense-css",
				"oxfmt",
				"!vscode-css-language-server"
			]
		}
	}
}

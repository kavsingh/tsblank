{
	"$schema": "./node_modules/lefthook/schema.json",
	"pre-commit": {
		"jobs": [
			{
				"glob": "*.{ts,tsx,js,jsx,html,css,json,jsonc,yml,yaml,toml,md}",
				"run": "bun oxfmt {staged_files}",
				"stage_fixed": true
			},
			{
				"glob": "*.{ts,tsx,js,jsx}",
				"run": "bun oxlint --fix {staged_files}",
				"stage_fixed": true
			}
		]
	},
	"pre-push": { "jobs": [{ "run": "bun lint" }] }
}

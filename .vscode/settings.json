{
	"files.watcherExclude": {
		"**/node_modules": true,
		"**/dist/": true
	},
	"search.exclude": {
		"**/node_modules": true,
		"**/dist/": true
	},

	"js/ts.experimental.useTsgo": true,
	"oxc.enable": true,

	"files.associations": { "*.css": "tailwindcss" },
	"tailwindCSS.validate": false,
	"tailwindCSS.classAttributes": [
		"class",
		"className",
		".+ClassName",
		".+ClassNames"
	],
	"tailwindCSS.classFunctions": ["twMerge", "twJoin", "tv"],
	"tailwindCSS.experimental.configFile": "src/index.css",

	"editor.formatOnSave": true,
	"editor.defaultFormatter": "oxc.oxc-vscode",
	"editor.codeActionsOnSave": { "source.fixAll.oxc": "always" },
	"editor.quickSuggestions": { "strings": true },

	"[css]": { "tailwindCSS.validate": true }
}

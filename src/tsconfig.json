{
	"extends": "../tsconfig.json",
	"compilerOptions": {
		"jsx": "react-jsx",
		"jsxImportSource": "preact",
		"lib": ["esnext", "dom", "dom.iterable"],
		"paths": { "#*": ["./*"] },
		"sourceMap": true,
		"types": ["@testing-library/jest-dom/vitest"]
	},
	"include": [
		"./**/*.ts",
		"./**/*.tsx",
		"./**/*.mts",
		"./**/*.mtsx",
		"./**/*.cts",
		"./**/*.ctsx",
		"./**/*.js",
		"./**/*.jsx",
		"./**/*.mjs",
		"./**/*.mjsx",
		"./**/*.cjs",
		"./**/*.cjsx"
	]
}
